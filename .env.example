# ---------------------------------------------------------------------------
# Local development environment.
#
# Copy this file to `.env` and it will boot the app and the test suite against a
# LOCAL, DISPOSABLE Postgres. The values below are working dev defaults — they
# are safe to commit as an example and safe to use locally. Do NOT reuse these
# secrets in staging/production, and NEVER point the test/seed commands at a
# real database (the seed and integration tests are destructive — they reset).
# ---------------------------------------------------------------------------

# Database
# Points at the disposable local Postgres from docker-compose.local.yml
# (or any local Postgres on :5432). The integration tests + seed only ever run
# against this; see CLAUDE.md > Testing.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cmms?schema=public"

# Auth (NextAuth v5)
# NEXTAUTH_SECRET and AUTH_SECRET MUST be identical. Replace with your own in
# any non-local environment (`openssl rand -base64 32`).
NEXTAUTH_SECRET="4xDm81d9Hz+kxtoXUhz9vtFmCW7UKGY8ZzdoB7MMZB0="
AUTH_SECRET="4xDm81d9Hz+kxtoXUhz9vtFmCW7UKGY8ZzdoB7MMZB0="
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Security / encryption
# REQUIRED in all environments. Roster medical/PII fields are written through
# lib/medical-data.ts, which throws ("MEDICAL_ENCRYPTION_KEY is not configured")
# if this is unset — so the roster screens and the seed will fail without it.
# Must be a 32-byte key as 64 hex chars OR a 32-byte base64 string.
# Generate one: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
MEDICAL_ENCRYPTION_KEY="9dbd45c9aaa614275b35fe2aaf24bcabddf35a158569b4cabd07e8095a9189b2"

# Consent document versioning
# Version identifier of the current waiver/consent document (e.g. "2025-v1").
# Stored on RosterMember when consent is recorded so you can track which version
# was agreed to.
CONSENT_DOCUMENT_VERSION="2025-v1"

# Email (Resend) — optional locally. Email sends are no-ops without a real key.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="CMMS <noreply@example.org>"
CONFERENCE_CONTACT_EMAIL="conference@example.org"

# Square Payments — optional locally; use sandbox values for any real testing.
# SQUARE_ACCESS_TOKEN: Bearer token from the Square Developer Dashboard (Applications > Credentials).
SQUARE_ACCESS_TOKEN="your-square-access-token-here"
# SQUARE_ENVIRONMENT: "sandbox" for testing, "production" for live payments.
SQUARE_ENVIRONMENT="sandbox"
# SQUARE_LOCATION_ID: The Square location ID to associate with payment links and orders.
SQUARE_LOCATION_ID="XXXXXXXXXXXXXXXX"
# SQUARE_WEBHOOK_SIGNATURE_KEY: Signature key from the Square Developer Dashboard
# (Webhooks > your endpoint > Signature key). Used to verify incoming webhook payloads.
SQUARE_WEBHOOK_SIGNATURE_KEY="replace-with-square-webhook-signature-key"

# Seed overrides (optional)
# The seed creates a Super Admin and a Club Director (see CLAUDE.md > Testing for
# the printed logins). Override the Super Admin here if you like.
SEED_SUPER_ADMIN_EMAIL="superadmin@cmms.local"
SEED_SUPER_ADMIN_PASSWORD="ChangeMeNow123!"
SEED_SUPER_ADMIN_NAME="CMMS Super Admin"
